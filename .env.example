# Quantarion AI Environment Variables

# Google Gemini API Key (Required)
# Get it from: https://makersuite.google.com/app/apikey
GEMINI_API_KEY=your_gemini_api_key_here

# IBM Quantum Token (Optional - for future integration)
# Get it from: https://quantum-computing.ibm.com/
IBM_QUANTUM_TOKEN=your_ibm_token_here

# Flask Configuration
FLASK_ENV=production
FLASK_DEBUG=False

# Application Port
PORT=5000
